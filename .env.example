# =========================
# Web App (Next.js)
# =========================

# Set to true only for UI preview mode with no live Supabase auth/data.
NEXT_PUBLIC_DEMO_MODE=false

# Public app URL used for auth redirects and emails.
NEXT_PUBLIC_APP_URL=https://your-app.example.com

# Public Supabase values for browser auth/session handling.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-side Supabase values used by API routes and auth handlers.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Must be the real service_role key, not the anon key.
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Optional: LiveKit egress -> Supabase S3-compatible storage for call recordings.
SUPABASE_S3_ACCESS_KEY=optional-s3-access-key
SUPABASE_S3_SECRET=optional-s3-secret

# Protects the retry cron endpoint.
CRON_SECRET=replace-with-a-long-random-secret

# Optional container/runtime overrides.
PORT=3011
HOSTNAME=0.0.0.0


# =========================
# AI Keys
# =========================

# Gemini / Google AI
GOOGLE_API_KEY=your-google-api-key
GEMINI_API_KEY=your-google-api-key


# =========================
# Python Agent Worker
# =========================

# Reuses:
# LIVEKIT_URL
# LIVEKIT_API_KEY
# LIVEKIT_API_SECRET
# SUPABASE_URL
# SUPABASE_SERVICE_KEY
# GOOGLE_API_KEY


# =========================
# Supabase Edge Functions
# =========================

# Reuses:
# SUPABASE_URL
# SUPABASE_SERVICE_KEY
# GEMINI_API_KEY
